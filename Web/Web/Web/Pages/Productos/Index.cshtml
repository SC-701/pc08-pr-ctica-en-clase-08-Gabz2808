@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Catálogo de Productos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h1 class="display-5 text-primary">📦 Catálogo de Productos</h1>
        <a asp-page="./Agregar" class="btn btn-success btn-lg shadow-sm">
            ➕ Agregar Nuevo
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (Model.Productos != null && Model.Productos.Any())
        {
            @foreach (var Producto in Model.Productos)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-dark mb-0">@Producto.Nombre</h5>
                                <span class="badge bg-secondary">@Producto.Categoria</span>
                            </div>
                            <h6 class="card-subtitle mb-3 text-muted">@Producto.SubCategoria</h6>

                            <p class="card-text mb-4">
                                <span class="fs-4 fw-bold text-success">$@Producto.Precio</span>
                                <br />
                                @if(Producto.Stock > 0)
                                {
                                    <small class="text-muted">Stock: @Producto.Stock unidades</small>
                                }
                                else
                                {
                                    <small class="text-danger fw-bold">Agotado</small>
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0 pb-3">
                            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                                <a class="btn btn-outline-info btn-sm flex-fill" asp-page="./Detalle" asp-route-id="@Producto.Id">🔍 Detalles</a>
                                <a class="btn btn-outline-warning btn-sm flex-fill" asp-page="./Editar" asp-route-id="@Producto.Id">✏️ Editar</a>
                                <a class="btn btn-outline-danger btn-sm flex-fill" asp-page="./Eliminar" asp-route-id="@Producto.Id">🗑️ Eliminar</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-info shadow-sm" role="alert">
                    <h4 class="mb-3">No hay productos registrados</h4>
                    <p class="mb-0">Comienza agregando un nuevo producto al catálogo.</p>
                </div>
            </div>
        }
    </div>
</div>