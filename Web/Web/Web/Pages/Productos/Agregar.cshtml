@page
@model Web.Pages.Productos.AgregarModel
@{
    ViewData["Title"] = "Agregar Producto";
}
<h1>Agregar Producto</h1>
<div class="container">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">

        <form method="post">
            <div class="form-group">
                <label for="categorias">Categoría</label>
                <select 
                        class="form-select"
                        asp-items="Model.categorias"
                        id="categorias"
                        asp-for="categoriaSeleccionada"
                        onchange="fectSubcategorias()">
                    <option value="">Seleccione una categoría</option>
                </select>
            </div>

            <div class="form-group">
                <label for="subcategorias">Subcategoría</label>
                <select asp-for="producto.IdSubCategoria"
                        class="form-select"
                        asp-items="Model.subcategorias"
                        id="subcategorias">
                    <option value="">Seleccione una subcategoría</option>
                </select>
                <span class="text-danger" asp-validation-for="producto.IdSubCategoria"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="producto.Nombre"></label>
                <input class="form-control" asp-for="producto.Nombre" />
                <span class="text-danger" asp-validation-for="producto.Nombre"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="producto.Descripcion"></label>
                <textarea class="form-control" asp-for="producto.Descripcion"></textarea>
                <span class="text-danger" asp-validation-for="producto.Descripcion"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="producto.Precio"></label>
                <input type="number" step="0.01" class="form-control" asp-for="producto.Precio" />
                <span class="text-danger" asp-validation-for="producto.Precio"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="producto.Stock"></label>
                <input type="number" class="form-control" asp-for="producto.Stock" />
                <span class="text-danger" asp-validation-for="producto.Stock"></span>
            </div>

            <div class="form-group">
                <label class="control-label" asp-for="producto.CodigoBarras">Código de Barras</label>
                <input class="form-control" asp-for="producto.CodigoBarras" />
                <span class="text-danger" asp-validation-for="producto.CodigoBarras"></span>
            </div>

            <div class="text-danger" asp-validation-summary="All"></div>

            <div class="form-group mt-3">
                <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                <input type="submit" value="Agregar" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        async function fectSubcategorias() {
            const categoriaId = document.getElementById("categorias").value;
            console.log(categoriaId);
            if (!categoriaId) return;

            try {
                const respuesta = await fetch(`?handler=ObtenerSubCategoria&categoriaID=${categoriaId}`);
                const subcategorias = await respuesta.json();

                const subcategoriaSelect = document.getElementById("subcategorias");
                subcategoriaSelect.innerHTML = '<option value="">Seleccione una subcategoría</option>';

                subcategorias.forEach(subcategoria => {
                    const option = document.createElement("option");
                    option.value = subcategoria.id;
                    option.text = subcategoria.nombre;
                    subcategoriaSelect.appendChild(option);
                });

            } catch (error) {
                console.error(error);
            }
        }
    </script>
}
