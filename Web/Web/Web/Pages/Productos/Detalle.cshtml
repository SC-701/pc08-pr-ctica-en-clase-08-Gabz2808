@page
@model Web.Pages.Productos.DetalleModel
@{
    ViewData["Title"] = "Detalle del Producto";
}

<style>
    .vintage-card {
        background-color: #fbf5e6; /* Old paper color */
        border: 2px solid #8b4513; /* Saddle brown */
        border-radius: 8px;
        box-shadow: 6px 6px 0px #8b4513;
        font-family: 'Georgia', serif;
        color: #3e2723;
    }
    .vintage-title {
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        color: #5d4037;
        border-bottom: 2px dashed #8b4513;
        padding-bottom: 10px;
    }
    .vintage-text {
        border-bottom: 1px dotted #d7ccc8;
        padding: 10px 0;
        margin: 0;
        font-size: 1.1rem;
    }
    .vintage-btn {
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        text-transform: uppercase;
        border: 2px solid #8b4513;
        box-shadow: 3px 3px 0px #8b4513;
        border-radius: 4px;
        color: #3e2723;
    }
    .vintage-btn:hover {
        transform: translate(3px, 3px);
        box-shadow: none;
        color: #3e2723;
    }
    .vintage-btn-warning {
        background-color: #ffb300;
    }
    .vintage-btn-light {
        background-color: #fff8e1;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="vintage-card p-4 p-md-5">
                <h2 class="vintage-title text-center mb-4">🕰️ @Html.DisplayFor(modelo => modelo.producto.Nombre)</h2>

                <div class="vintage-text">
                    <b>@Html.DisplayNameFor(modelo => modelo.producto.Descripcion): </b> @Html.DisplayFor(modelo => modelo.producto.Descripcion)
                </div>
                <div class="vintage-text">
                    <b>@Html.DisplayNameFor(modelo => modelo.producto.Precio): </b> $@Html.DisplayFor(modelo => modelo.producto.Precio)
                </div>
                <div class="vintage-text">
                    <b>Precio (USD): </b> $@Html.DisplayFor(modelo => modelo.producto.PrecioUSD)
                </div>
                <div class="vintage-text">
                    <b>@Html.DisplayNameFor(modelo => modelo.producto.Stock): </b> @Html.DisplayFor(modelo => modelo.producto.Stock) unidades
                </div>
                <div class="vintage-text">
                    <b>@Html.DisplayNameFor(modelo => modelo.producto.Categoria): </b> @Html.DisplayFor(modelo => modelo.producto.Categoria)
                </div>
                <div class="vintage-text">
                    <b>@Html.DisplayNameFor(modelo => modelo.producto.SubCategoria): </b> @Html.DisplayFor(modelo => modelo.producto.SubCategoria)
                </div>

                <div class="mt-4 text-center">
                    <small class="text-muted" style="font-family: 'Courier New', Courier, monospace;">
                        📠 Código de Barras: @Html.DisplayFor(modelo => modelo.producto.CodigoBarras)
                    </small>
                </div>

                <div class="d-flex justify-content-center gap-4 mt-5">
                    <a class="btn vintage-btn vintage-btn-light px-4" asp-page="./Index">📜 Regresar</a>
                    <a class="btn vintage-btn vintage-btn-warning px-4" asp-page="./Editar" asp-route-id="@Model.producto.Id">✍️ Editar</a>
                </div>
            </div>
        </div>
    </div>
</div>